PORT=3000
BASE_URL=https://your-domain.railway.app

# JWT Secret (change this to a random string)
JWT_SECRET=change-this-to-something-random-and-long

# Admin account (set before seeding)
ADMIN_EMAIL=admin@puregreen.com
ADMIN_PASSWORD=YourAdminPassword2024!

# Admin notification emails (up to 3)
ADMIN_EMAIL_1=marko@puregreen.com
ADMIN_EMAIL_2=colleague2@puregreen.com
ADMIN_EMAIL_3=colleague3@puregreen.com

# Gmail SMTP (use an App Password, not your real password)
# Go to: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Admin seed secret (one-time use to create the admin account)
SEED_SECRET=puregreenadmin2024
